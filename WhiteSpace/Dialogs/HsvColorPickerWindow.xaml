<Window x:Class="WhiteSpace.Dialogs.HsvColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Цвет"
        Width="292"
        SizeToContent="Height"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <StackPanel Margin="14,12">
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="EyedropperButton"
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    Padding="0"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    ToolTip="Пипетка (клик по экрану)"
                    Click="EyedropperButton_Click"
                    Background="#F5F5F5"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <Path Data="M 6 18 L 6 22 L 10 22 L 18 14 L 14 10 Z M 14 10 L 17 7 L 17 4 L 14 1 L 11 4 L 11 7 Z"
                      Stroke="#222"
                      StrokeThickness="1.2"
                      StrokeLineJoin="Round"
                      Fill="#222"
                      Width="20"
                      Height="22"
                      Stretch="Uniform"/>
            </Button>
            <TextBox x:Name="HexBox"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     FontSize="14"
                     Padding="8,6"
                     BorderBrush="#3A7AFE"
                     MaxLength="9"
                     LostFocus="HexBox_OnLostFocus"
                     KeyDown="HexBox_OnKeyDown"/>
        </Grid>

        <Grid Height="32" Margin="0,0,0,10">
            <Border Height="14"
                    VerticalAlignment="Center"
                    CornerRadius="7"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF0000" Offset="0"/>
                        <GradientStop Color="#FFFF00" Offset="0.166"/>
                        <GradientStop Color="#00FF00" Offset="0.333"/>
                        <GradientStop Color="#00FFFF" Offset="0.5"/>
                        <GradientStop Color="#0000FF" Offset="0.666"/>
                        <GradientStop Color="#FF00FF" Offset="0.833"/>
                        <GradientStop Color="#FF0000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Slider x:Name="HueSlider"
                    Minimum="0"
                    Maximum="360"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    ValueChanged="HueSlider_ValueChanged"/>
        </Grid>

        <Border x:Name="SbBorder"
                Width="220"
                Height="180"
                HorizontalAlignment="Left"
                CornerRadius="8"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                ClipToBounds="True"
                MouseLeftButtonDown="SbBorder_OnMouseLeftButtonDown"
                MouseMove="SbBorder_OnMouseMove"
                MouseLeftButtonUp="SbBorder_OnMouseLeftButtonUp">
            <Grid>
                <Image x:Name="SbImage"
                       Stretch="Fill"
                       Width="220"
                       Height="180"/>
                <Canvas x:Name="SbOverlay" IsHitTestVisible="False">
                    <Ellipse x:Name="SbRing"
                             Width="14"
                             Height="14"
                             Stroke="White"
                             StrokeThickness="2"
                             Fill="Transparent"/>
                </Canvas>
            </Grid>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Отмена"
                    Width="88"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="OK"
                    Width="88"
                    IsDefault="True"
                    Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
