<Window x:Class="WhiteSpace.Dialogs.BoardVersionHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История версий доски"
        Width="520"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WsPageBgBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Облачные версии доски. Выберите версию для восстановления или удалите ненужные."
                   TextWrapping="Wrap"
                   FontSize="14"
                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                   Margin="0,0,0,12"/>
        <ListBox x:Name="VersionsList"
                 Grid.Row="1"
                 SelectionMode="Single"
                 DisplayMemberPath="DisplayLabel"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="DeleteVersionButton"
                    Content="Удалить"
                    Width="100"
                    Margin="0,0,10,0"
                    Padding="12,8"
                    Click="Delete_Click"/>
            <Button Content="Восстановить"
                    Width="120"
                    Margin="0,0,10,0"
                    Padding="12,8"
                    Click="Restore_Click"/>
            <Button Content="Закрыть"
                    Width="100"
                    Padding="12,8"
                    IsCancel="True"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
