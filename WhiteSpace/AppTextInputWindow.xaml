<Window x:Class="WhiteSpace.AppTextInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhiteSpace"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Opacity="0"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="AnimatedPrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource WsPurpleBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A78BFA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnimatedSecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Width="440"
                Margin="18"
                Background="Transparent"
                CornerRadius="20"
                BorderBrush="{DynamicResource WsBorderBrush}"
                BorderThickness="1.5"
                ClipToBounds="True">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DialogTranslate" Y="18"/>
            </Border.RenderTransform>

            <Border Background="{DynamicResource WsSurfaceBrush}" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource WsPurpleBrush}"
                            HorizontalAlignment="Stretch"
                            CornerRadius="18,18,0,0"/>

                    <StackPanel Grid.Row="1" Margin="28,24,28,18">
                        <TextBlock x:Name="TitleText"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="MessageText"
                                   Margin="0,10,0,0"
                                   FontSize="15"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBox x:Name="InputTextBox"
                                 Margin="0,16,0,0"
                                 Padding="12,10"
                                 FontSize="15"
                                 Background="{DynamicResource WsSurfaceMutedBrush}"
                                 Foreground="{DynamicResource WsTextPrimaryBrush}"
                                 BorderBrush="{DynamicResource WsBorderBrush}"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="28,0,28,26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="CancelButton"
                                Grid.Column="0"
                                Width="120"
                                Margin="0,0,12,0"
                                Content="Отмена"
                                Style="{StaticResource AnimatedSecondaryButton}"
                                Click="CancelButton_Click"/>

                        <Button x:Name="ConfirmButton"
                                Grid.Column="1"
                                Width="140"
                                Content="Создать"
                                Style="{StaticResource AnimatedPrimaryButton}"
                                Click="ConfirmButton_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
