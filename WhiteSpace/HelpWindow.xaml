<Window x:Class="WhiteSpace.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Инструкция"
        Height="620" Width="920"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WsPageBgBrush}">

    <Window.Resources>
        <Style x:Key="HelpNavListStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WsSurfaceBrush}"
                BorderBrush="{DynamicResource WsBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BackButton"
                        Padding="14,6"
                        Margin="0,0,10,0"
                        Click="BackButton_Click"
                        ToolTip="Предыдущий раздел">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="←" Margin="0,0,6,0"/>
                        <TextBlock Text="Назад"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Справочная система WhiteSpace"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource WsTextSecondaryBrush}"
                           FontSize="13"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource WsSidebarBgBrush}"
                    BorderBrush="{DynamicResource WsSidebarBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="10,12">
                <ListBox x:Name="TopicsListBox"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="White"
                         DisplayMemberPath="Title"
                         ItemContainerStyle="{StaticResource HelpNavListStyle}"
                         SelectionChanged="TopicsListBox_SelectionChanged"/>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Padding="24,20"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ContentPanel">
                    <TextBlock x:Name="TopicTitleText"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WsTextPrimaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>
                    <ItemsControl x:Name="ParagraphsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource WsTextSecondaryBrush}"
                                           FontSize="14"
                                           LineHeight="22"
                                           Margin="0,0,0,12"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
