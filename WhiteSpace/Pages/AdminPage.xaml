<Page x:Class="WhiteSpace.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Админка"
      Background="{DynamicResource WsPageBgBrush}"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="AdminButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminButtonStyle}">
            <Setter Property="Foreground" Value="#B42318"/>
            <Setter Property="BorderBrush" Value="#F2B8B5"/>
            <Setter Property="Background" Value="#FFF7F7"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AdminButtonStyle}">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#8B5CF6"/>
            <Setter Property="Background" Value="#8B5CF6"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="56"/>
            <Setter Property="ColumnHeaderHeight" Value="38"/>
            <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource WsBorderBrush}"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="AdminRootGrid" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Style="{StaticResource AdminButtonStyle}"
                    Width="118"
                    Content="Назад"
                    Click="Back_Click"/>

            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <TextBlock Text="Панель Администратора"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                <TextBlock x:Name="AccessHintTextBlock"
                           Margin="0,4,0,0"
                           Text="Управление пользователями, досками и доступами"
                           FontSize="14"
                           Foreground="{DynamicResource WsTextSecondaryBrush}"
                           Visibility="Collapsed"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Style="{StaticResource HelpRoundButtonStyle}"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Click="Help_Click"/>
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="Обновить"
                        Click="Refresh_Click"/>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,0,0,14">
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Пользователи" Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                    <TextBlock x:Name="UsersCountTextBlock" Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Доски" Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                    <TextBlock x:Name="BoardsCountTextBlock" Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Элементы" Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                    <TextBlock x:Name="ShapesCountTextBlock" Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Активны за 7 дней" Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                    <TextBlock x:Name="ActiveUsersTextBlock" Text="0" Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Style="{StaticResource PanelBorderStyle}"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource WsTextSecondaryBrush}"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Height="38"
                         Margin="12,0"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <ComboBox x:Name="ScopeComboBox"
                          Grid.Column="2"
                          Width="170"
                          Height="38"
                          Margin="0,0,10,0"
                          VerticalContentAlignment="Center"
                          SelectionChanged="ScopeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Пользователи" IsSelected="True"/>
                    <ComboBoxItem Content="Доски"/>
                    <ComboBoxItem Content="Права доступа"/>
                </ComboBox>
                <Button Grid.Column="3"
                        Style="{StaticResource AdminButtonStyle}"
                        Width="128"
                        Margin="0,0,10,0"
                        Content="Сбросить фильтр"
                        Click="ClearFilters_Click"/>
                <TextBlock x:Name="UpdatedAtTextBlock"
                           Grid.Column="4"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource WsTextSecondaryBrush}"/>
            </Grid>
        </Border>

        <TabControl x:Name="AdminTabControl" Grid.Row="3">
            <TabControl.Resources>
                <Style TargetType="{x:Type TabPanel}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>
            <TabItem Header="Пользователи">
                <Border Style="{StaticResource PanelBorderStyle}" Padding="0">
                    <DataGrid x:Name="UsersGrid"
                              ItemsSource="{Binding Users}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Username}" Width="1.4*"/>
                            <DataGridTextColumn Header="Создан" Binding="{Binding CreatedText}" Width="1.1*"/>
                            <DataGridTextColumn Header="Свои доски" Binding="{Binding OwnedBoardsCount}" Width="0.8*"/>
                            <DataGridTextColumn Header="Доступы" Binding="{Binding MembershipsCount}" Width="0.8*"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding PresenceLabel}" Width="0.9*"/>
                            <DataGridTextColumn Header="Активность" Binding="{Binding LastActivityText}" Width="1.2*"/>
                            <DataGridTemplateColumn Header="Действия" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource AdminButtonStyle}"
                                                    Content="ID"
                                                    CommandParameter="{Binding}"
                                                    Click="CopyUserId_Click"/>
                                            <Button Style="{StaticResource DangerButtonStyle}"
                                                    Content="Удалить"
                                                    IsEnabled="{Binding CanDeleteProfile}"
                                                    CommandParameter="{Binding}"
                                                    Click="DeleteUser_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Доски">
                <Border Style="{StaticResource PanelBorderStyle}" Padding="0">
                    <DataGrid x:Name="BoardsGrid"
                              ItemsSource="{Binding Boards}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="2*"/>
                            <DataGridTextColumn Header="Владелец" Binding="{Binding OwnerLabel}" Width="1.6*"/>
                            <DataGridTextColumn Header="Код" Binding="{Binding AccessCode}" Width="0.8*"/>
                            <DataGridTextColumn Header="Создана" Binding="{Binding CreatedText}" Width="1.1*"/>
                            <DataGridTextColumn Header="Участники" Binding="{Binding MembersCount}" Width="0.8*"/>
                            <DataGridTextColumn Header="Элементы" Binding="{Binding ShapesCount}" Width="0.8*"/>
                            <DataGridTemplateColumn Header="Действия" Width="360">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource AdminButtonStyle}"
                                                    Content="Открыть"
                                                    CommandParameter="{Binding}"
                                                    Click="OpenBoard_Click"/>
                                            <Button Style="{StaticResource AdminButtonStyle}"
                                                    Content="Код"
                                                    CommandParameter="{Binding}"
                                                    Click="CopyBoardCode_Click"/>
                                            <Button Style="{StaticResource DangerButtonStyle}"
                                                    Content="Контент"
                                                    IsEnabled="{Binding CanClearContent}"
                                                    CommandParameter="{Binding}"
                                                    Click="ClearBoardContent_Click"/>
                                            <Button Style="{StaticResource DangerButtonStyle}"
                                                    Content="Удалить"
                                                    IsEnabled="{Binding CanDeleteBoard}"
                                                    CommandParameter="{Binding}"
                                                    Click="DeleteBoard_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Права доступа">
                <Border Style="{StaticResource PanelBorderStyle}" Padding="0">
                    <DataGrid x:Name="MembersGrid"
                              ItemsSource="{Binding Members}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Доска" Binding="{Binding BoardTitle}" Width="2*"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding UserLabel}" Width="2*"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleLabel}" Width="1*"/>
                            <DataGridTextColumn Header="Добавлен" Binding="{Binding JoinedText}" Width="0.8*"/>
                            <DataGridTemplateColumn Header="Действия" Width="320">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource AdminButtonStyle}"
                                                    Content="{Binding ToggleRoleButtonLabel}"
                                                    IsEnabled="{Binding CanManageAccess}"
                                                    CommandParameter="{Binding}"
                                                    Click="ToggleRole_Click"/>
                                            <Button Style="{StaticResource DangerButtonStyle}"
                                                    Content="Убрать"
                                                    IsEnabled="{Binding CanManageAccess}"
                                                    CommandParameter="{Binding}"
                                                    Click="RemoveAccess_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="4"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
    </Grid>
</Page>
