<Page x:Class="WhiteSpace.Pages.UserSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Настройки пользователя"
      Background="{DynamicResource WsPageBgBrush}"
      Loaded="Page_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Width="130"
                    Height="40"
                    Content="← Назад"
                    Click="Back_Click"/>
            <TextBlock Grid.Column="1"
                       Margin="16,7,16,0"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource WsTextPrimaryBrush}"
                       Text="Настройки пользователя"
                       TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="2"
                    Style="{StaticResource HelpRoundButtonStyle}"
                    VerticalAlignment="Center"
                    Click="Help_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource WsSurfaceBrush}"
                        BorderBrush="{DynamicResource WsBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Профиль"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                        <TextBlock Text="Имя пользователя"
                                   Margin="0,12,0,4"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                        <TextBox x:Name="UsernameBox"
                                 Height="40"
                                 Foreground="{DynamicResource WsTextPrimaryBrush}"
                                 Background="{DynamicResource WsSurfaceBrush}"
                                 BorderBrush="{DynamicResource WsBorderBrush}"/>
                        <TextBlock Text="Email"
                                   Margin="0,12,0,4"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                        <TextBlock Text="Адрес привязан к аккаунту и не может быть изменён здесь."
                                   FontSize="12"
                                   Foreground="{DynamicResource WsTextMutedBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="EmailBox"
                                 Height="40"
                                 IsReadOnly="True"
                                 Focusable="False"
                                 Cursor="Arrow"
                                 Background="{DynamicResource WsSurfaceMutedBrush}"
                                 BorderBrush="{DynamicResource WsBorderBrush}"
                                 Foreground="{DynamicResource WsTextPrimaryBrush}"
                                 ToolTip="Только просмотр. Смена email выполняется через поддержку или в учётной записи провайдера."/>
                        <Button Margin="0,14,0,0"
                                Height="42"
                                Content="Сохранить имя"
                                Click="SaveUsername_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource WsSurfaceBrush}"
                        BorderBrush="{DynamicResource WsBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Безопасность"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                        <TextBlock Text="Новый пароль"
                                   Margin="0,12,0,4"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                        <PasswordBox x:Name="NewPasswordBox"
                                     Height="40"/>
                        <TextBlock Text="Повторите пароль"
                                   Margin="0,12,0,4"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Height="40"/>
                        <Button Margin="0,14,0,0"
                                Height="42"
                                Content="Обновить пароль"
                                Click="SavePassword_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource WsSurfaceBrush}"
                        BorderBrush="{DynamicResource WsBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Поведение интерфейса"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                        <TextBlock Text="Тема оформления"
                                   Margin="0,14,0,4"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                        <ComboBox x:Name="ThemeComboBox"
                                  Width="280"
                                  Height="40"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,8"
                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Светлая" Tag="Light"/>
                            <ComboBoxItem Content="Тёмная" Tag="Dark"/>
                        </ComboBox>
                        <CheckBox x:Name="CompactViewCheckBox"
                                  Margin="0,14,0,0"
                                  Content="Компактный вид карточек по умолчанию"/>
                        <CheckBox x:Name="ConfirmLogoutCheckBox"
                                  Margin="0,10,0,0"
                                  Content="Подтверждать выход из аккаунта"/>
                        <CheckBox x:Name="AnimationsCheckBox"
                                  Margin="0,10,0,0"
                                  Content="Включить анимации интерфейса"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,16,0,0">
                            <Button Width="180"
                                    Height="42"
                                    Margin="0,0,12,0"
                                    Content="Сохранить настройки"
                                    Click="SavePreferences_Click"/>
                            <Button Width="220"
                                    Height="42"
                                    Content="Очистить недавние доски"
                                    Click="ClearRecentBoards_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
