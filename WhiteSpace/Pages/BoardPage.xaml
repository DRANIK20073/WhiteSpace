                        <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xE70B;"/>
                    </Button>
                    <Button x:Name="ArrowToolButton" Style="{StaticResource ToolbarButtonStyle}" Click="ArrowTool_Click"
