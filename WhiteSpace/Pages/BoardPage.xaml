<Page x:Class="WhiteSpace.Pages.BoardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Доска"
      Background="{DynamicResource WsPageBgBrush}">

    <Page.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ToolbarScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ToolbarScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.04" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ToolbarScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.04" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ToolbarScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ToolbarScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#8B5CF6"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DarkActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderBrush" Value="#8B5CF6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка открытия чата: плавное наведение и нажатие -->
        <Style x:Key="ChatFabButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="FabRoot"
                                Background="{TemplateBinding Background}"
                                CornerRadius="28"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="FabScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.2" Color="#000000"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsPressed" Value="True"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.90" Duration="0:0:0.09">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.90" Duration="0:0:0.09">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="FabRoot"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#7C3AED" Duration="0:0:0.09"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsPressed" Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.09" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.09" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="FabRoot"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#A78BFA" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="FabRoot"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#8B5CF6" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="BoardRootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WsSurfaceBrush}"
                BorderBrush="{DynamicResource WsBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderActionButtonStyle}"
                            Margin="0,0,10,0"
                            Click="BackToMenu_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="←" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Меню"/>
                        </StackPanel>
                    </Button>

                    <Border Width="38"
                            Height="38"
                            CornerRadius="12"
                            Background="#8B5CF6"
                            Margin="0,0,12,0">
                        <TextBlock Text="W"
                                   Foreground="#FFFFFF"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="BoardTitleText"
                                   Text="Моя доска"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="SaveStatusText"
                                   Text="Сохранено"
                                   Margin="14,5,0,0"
                                   FontSize="15"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ViewerModeText"
                                   Text="Режим наблюдателя: редактирование недоступно"
                                   Margin="14,5,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#C47F00"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderActionButtonStyle}"
                            Click="Share_Click">
                        <TextBlock Text="Поделиться"/>
                    </Button>

                    <Button Style="{StaticResource DarkActionButtonStyle}"
                            Margin="8,0,0,0"
                            Click="SaveBoard_Click">
                        <TextBlock Text="Сохранить"/>
                    </Button>

                    <Button x:Name="BoardMenuButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="8,0,0,0"
                            Padding="12,10"
                            Click="BoardMenuButton_Click">
                        <TextBlock Text="⋮" FontSize="18"/>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="BoardOptionsMenu"
                                         Placement="Bottom">
                                <MenuItem Header="Включить режим презентации"
                                          Click="PresentationMode_Click"/>
                                <MenuItem Header="Сохранить версию"
                                          Click="SaveVersion_Click"/>
                                <MenuItem Header="История версий"
                                          Click="VersionHistory_Click"/>
                                <Separator/>
                                <MenuItem Header="Удалить доску"
                                          Foreground="#D92D20"
                                          Click="DeleteBoardMenu_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource WsSurfaceBrush}"
                BorderBrush="{DynamicResource WsBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,10">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="HandButton" Style="{StaticResource ToolbarButtonStyle}" Content="Рука" Click="Hand_Click"/>
                    <Button x:Name="PenButton" Style="{StaticResource ToolbarButtonStyle}" Content="Перо" Click="Pen_Click"/>
                    <Button x:Name="RectButton" Style="{StaticResource ToolbarButtonStyle}" Content="Квадрат" Click="Rect_Click"/>
                    <Button x:Name="EllipseButton" Style="{StaticResource ToolbarButtonStyle}" Content="Круг" Click="Ellipse_Click"/>
                    <Button x:Name="TextButton" Style="{StaticResource ToolbarButtonStyle}" Content="Текст" Click="Text_Click"/>

                    <Border Width="1" Height="32" Background="{DynamicResource WsBorderBrush}" Margin="8,0,12,0"/>

                    <StackPanel x:Name="ColorPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                        <Button Background="#111111" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#FF3B30" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#34C759" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#007AFF" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#FFD60A" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#FF2DDA" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#32D7FF" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#FF9500" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#AF52DE" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#30B0C7" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Border Width="1" Height="32" Background="{DynamicResource WsBorderBrush}" Margin="8,0,12,0"/>
                        <Button x:Name="UndoButton" Style="{StaticResource ToolbarButtonStyle}" Content="↶" Click="Undo_Click"/>
                        <Button x:Name="RedoButton" Style="{StaticResource ToolbarButtonStyle}" Content="↷" Click="Redo_Click"/>
                        <Button x:Name="ClearBoardButton" Style="{StaticResource ToolbarButtonStyle}" Content="🗑" Click="ClearBoard_Click"/>
                        <Button x:Name="AddImageButton" Style="{StaticResource ToolbarButtonStyle}" Content="🖼" Click="AddImage_Click"/>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="PNG" Click="ExportPng_Click"/>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="PDF" Click="ExportPdf_Click"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource WsSurfaceBrush}"
                    ClipToBounds="True">
                <Grid x:Name="Viewport"
                      MouseDown="Viewport_MouseDown"
                      MouseMove="Viewport_MouseMove"
                      MouseUp="Viewport_MouseUp"
                      MouseWheel="Viewport_MouseWheel"
                      Background="{DynamicResource WsViewportGradientBrush}">

                    <Canvas x:Name="BoardCanvas" Width="50000" Height="50000">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="BoardScale" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="BoardTranslate" X="0" Y="0"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>
                    <Canvas x:Name="CursorCanvas"
                            Width="50000"
                            Height="50000"
                            IsHitTestVisible="False">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding ElementName=BoardScale, Path=ScaleX}"
                                                ScaleY="{Binding ElementName=BoardScale, Path=ScaleY}"/>
                                <TranslateTransform X="{Binding ElementName=BoardTranslate, Path=X}"
                                                    Y="{Binding ElementName=BoardTranslate, Path=Y}"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsBorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="18,16,18,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Участники"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                            <Border Background="{DynamicResource WsSurfaceMutedBrush}"
                                    CornerRadius="9"
                                    Margin="8,1,0,0"
                                    Padding="8,2">
                                <TextBlock x:Name="MembersCountText"
                                           Text="0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource DarkActionButtonStyle}"
                                Padding="14,8"
                                Click="Invite_Click">
                            <TextBlock Text="Пригласить"/>
                        </Button>
                    </Grid>

                    <ListView x:Name="UsersListView"
                              Grid.Row="1"
                              Margin="10,0,10,12"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WsSurfaceMutedBrush}"
                                        BorderBrush="{DynamicResource WsBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="42" Height="42" VerticalAlignment="Top">
                                            <Border Background="{Binding AvatarFill}"
                                                    BorderBrush="{Binding AvatarStroke}"
                                                    BorderThickness="2"
                                                    CornerRadius="21"/>
                                            <TextBlock Text="{Binding Initials}"
                                                       Foreground="{Binding AvatarStroke}"
                                                       FontWeight="SemiBold"
                                                       FontSize="17"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Fill="{Binding PresenceDotFill}"
                                                     Stroke="#FFFFFF"
                                                     StrokeThickness="2"
                                                     HorizontalAlignment="Right"
                                                     VerticalAlignment="Bottom"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="16"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CurrentUserHint}"
                                                       Margin="0,2,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                       Visibility="{Binding CurrentUserHintVisibility}"/>
                                            <TextBlock Text="{Binding PresenceLabel}"
                                                       Margin="0,2,0,0"
                                                       FontSize="12"
                                                       Foreground="{Binding PresenceTextFill}"/>
                                            <Border Background="{Binding RoleBadgeBackground}"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="10"
                                                    Margin="0,6,0,0"
                                                    Padding="10,3">
                                                <TextBlock Text="{Binding RoleLabel}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding RoleBadgeForeground}"/>
                                            </Border>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Content="⋯"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                Width="34"
                                                Height="34"
                                                Padding="0"
                                                Margin="8,0,0,0"
                                                Click="ParticipantActionsButton_Click"
                                                Visibility="{Binding ActionVisibility}">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{Binding RoleActionLabel}"
                                                              Visibility="{Binding RoleActionVisibility}"
                                                              Click="ToggleParticipantRoleMenu_Click"/>
                                                    <MenuItem Header="Скопировать ID пользователя"
                                                              Click="CopyParticipantIdMenu_Click"/>
                                                    <Separator Visibility="{Binding RemoveActionVisibility}"/>
                                                    <MenuItem Header="Удалить с доски"
                                                              Foreground="#D92D20"
                                                              Visibility="{Binding RemoveActionVisibility}"
                                                              Click="RemoveParticipantMenu_Click"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.ColumnSpan="2">
                <Grid HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,18,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="ChatWidget"
                            Grid.Row="0"
                            Width="360"
                            Background="{DynamicResource WsChatPanelBgBrush}"
                            BorderBrush="{DynamicResource WsBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Visibility="Collapsed"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="16,14,16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Чат"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                                <Button Grid.Column="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource WsTextSecondaryBrush}"
                                        FontSize="18"
                                        Cursor="Hand"
                                        Click="CloseChat_Click"
                                        Content="×"/>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          x:Name="ChatMessagesScrollViewer"
                                          Margin="16,0,16,12"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ChatMessagesItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="{Binding HeaderText}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                           HorizontalAlignment="{Binding HeaderAlignment}"/>
                                                <Border HorizontalAlignment="{Binding BubbleAlignment}"
                                                        MaxWidth="280"
                                                        Margin="0,4,0,0"
                                                        CornerRadius="14"
                                                        Padding="12,8"
                                                        Background="{Binding BubbleBackground}"
                                                        ContextMenuOpening="ChatBubble_ContextMenuOpening">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Редактировать"
                                                                      Click="ChatMessageEdit_Click"/>
                                                            <MenuItem Header="Удалить"
                                                                      Foreground="#DC2626"
                                                                      Click="ChatMessageDelete_Click"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <TextBlock Text="{Binding Text}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{Binding TextForeground}"/>
                                                </Border>
                                                <TextBlock Text="изменено"
                                                           FontSize="11"
                                                           FontStyle="Italic"
                                                           Foreground="{DynamicResource WsTextMutedBrush}"
                                                           Margin="0,3,0,0"
                                                           HorizontalAlignment="{Binding BubbleAlignment}"
                                                           Visibility="{Binding EditedBadgeVisibility}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Grid Grid.Row="2" Margin="16,0,16,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="ChatInputBox"
                                         Height="42"
                                         VerticalContentAlignment="Center"
                                         Padding="14,0"
                                         Background="{DynamicResource WsChatInputBgBrush}"
                                         BorderBrush="{DynamicResource WsBorderBrush}"
                                         Foreground="{DynamicResource WsTextPrimaryBrush}"
                                         BorderThickness="1"
                                         Text=""
                                         KeyDown="ChatInputBox_KeyDown"/>

                                <Button Grid.Column="1"
                                        Width="42"
                                        Height="42"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource DarkActionButtonStyle}"
                                        Click="ChatSend_Click">
                                    <TextBlock Text="➜"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <Button Grid.Row="1"
                            Style="{StaticResource ChatFabButtonStyle}"
                            Click="ToggleChat_Click">
                        <TextBlock Text="💬" FontSize="18"/>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
