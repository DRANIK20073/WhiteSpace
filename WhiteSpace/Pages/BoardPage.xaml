<Page x:Class="WhiteSpace.Pages.BoardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Доска"
      Background="{DynamicResource WsPageBgBrush}">

    <Page.Resources>
        <Style x:Key="ToolbarMdl2IconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
        </Style>

        <Style x:Key="ToolbarLetterIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
        </Style>

        <Style x:Key="ToolbarBadgeLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource ToolbarLetterIconStyle}">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- ListView по умолчанию рисует светлую рамку вокруг ScrollViewer — в тёмной теме даёт «просвет». -->
        <Style x:Key="BoardParticipantsListViewStyle" TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Padding="{TemplateBinding Padding}"
                                          Focusable="False"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="Transparent"
                                          BorderThickness="0">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectionToolbarDeleteButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource WsPurpleBrush}"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WsTopButtonPressBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectionToolbarColorChipStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource WsPurpleBrush}"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WsTopButtonPressBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ToolbarScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ToolbarScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.14"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ToolbarScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.14"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ToolbarScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ToolbarScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DarkActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderBrush" Value="#8B5CF6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SwatchRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="SwatchScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="SwatchRoot" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter TargetName="SwatchRoot" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwatchScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.14"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="SwatchScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.14"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwatchScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="SwatchScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка открытия чата: плавное наведение и нажатие -->
        <Style x:Key="ChatFabButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="FabRoot"
                                Background="{TemplateBinding Background}"
                                CornerRadius="28"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="FabScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.2" Color="#000000"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsPressed" Value="True"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.90" Duration="0:0:0.09">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.90" Duration="0:0:0.09">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="FabRoot"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#7C3AED" Duration="0:0:0.09"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsPressed" Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.09" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.09" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="FabRoot"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#A78BFA" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="FabScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="FabRoot"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#8B5CF6" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="BoardRootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WsSurfaceBrush}"
                BorderBrush="{DynamicResource WsBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource HeaderActionButtonStyle}"
                            Margin="0,0,10,0"
                            Click="BackToMenu_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="←" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Меню"/>
                        </StackPanel>
                    </Button>

                    <Border Width="38"
                            Height="38"
                            CornerRadius="12"
                            Background="#8B5CF6"
                            Margin="0,0,12,0">
                        <TextBlock Text="W"
                                   Foreground="#FFFFFF"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="BoardTitleText"
                                   Text="Моя доска"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="SaveStatusText"
                                   Text="Сохранено"
                                   Margin="14,5,0,0"
                                   FontSize="15"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ViewerModeText"
                                   Text="Режим наблюдателя: редактирование недоступно"
                                   Margin="14,5,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#C47F00"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PresentationModeBanner"
                                   Text="Презентация: редактирование только у ведущего"
                                   Margin="14,5,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#7C3AED"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource HelpRoundButtonStyle}"
                            Margin="0,0,8,0"
                            Click="Help_Click"/>
                    <Button Style="{StaticResource HeaderActionButtonStyle}"
                            Click="Share_Click">
                        <TextBlock Text="Поделиться"/>
                    </Button>

                    <Button x:Name="BoardMenuButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="8,0,0,0"
                            Padding="12,10"
                            Click="BoardMenuButton_Click">
                        <TextBlock Text="⋮" FontSize="18"/>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="BoardOptionsMenu"
                                         Placement="Bottom">
                                <MenuItem x:Name="PresentationMenuItem"
                                          Header="Включить режим презентации"
                                          Click="PresentationMode_Click"/>
                                <MenuItem x:Name="SaveVersionMenuItem"
                                          Header="Сохранить версию"
                                          Click="SaveVersion_Click"/>
                                <MenuItem x:Name="VersionHistoryMenuItem"
                                          Header="История версий"
                                          Click="VersionHistory_Click"/>
                                <Separator/>
                                <MenuItem Header="Удалить доску"
                                          Foreground="#D92D20"
                                          Click="DeleteBoardMenu_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource WsSurfaceBrush}"
                BorderBrush="{DynamicResource WsBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,10">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- Навигация: выделение, рука -->
                    <Button x:Name="SelectButton" Style="{StaticResource ToolbarButtonStyle}" Click="Select_Click"
                            ToolTip="Выделение (V)">
                        <Viewbox Width="18" Height="18">
                            <Rectangle Width="16" Height="16"
                                       Stroke="{DynamicResource WsTextPrimaryBrush}"
                                       StrokeThickness="1.5"
                                       StrokeDashArray="2.5 2"
                                       Fill="Transparent"
                                       RadiusX="1"
                                       RadiusY="1"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="HandButton" Style="{StaticResource ToolbarButtonStyle}" Click="Hand_Click"
                            ToolTip="Рука — перемещение по доске (H)">
                        <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xF271;"/>
                    </Button>

                    <Border Width="1" Height="28" Background="{DynamicResource WsBorderBrush}" Margin="6,0,8,0" VerticalAlignment="Center"/>

                    <!-- Рисование -->
                    <Button x:Name="PenButton" Style="{StaticResource ToolbarButtonStyle}" Click="Pen_Click"
                            ToolTip="Перо (P)">
                        <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xED63;"/>
                    </Button>
                    <Button x:Name="MarkerButton" Style="{StaticResource ToolbarButtonStyle}" Click="Marker_Click"
                            ToolTip="Маркер">
                        <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xED64;"/>
                    </Button>
                    <Button x:Name="EraserButton" Style="{StaticResource ToolbarButtonStyle}" Click="Eraser_Click"
                            ToolTip="Стерка">
                        <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xED62;"/>
                    </Button>

                    <Border Width="1" Height="28" Background="{DynamicResource WsBorderBrush}" Margin="6,0,8,0" VerticalAlignment="Center"/>

                    <!-- Объекты -->
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ShapesToolButton" Style="{StaticResource ToolbarButtonStyle}" Click="ShapesToolButton_Click"
                                ToolTip="Фигуры" Padding="8,8" MinWidth="44">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="22" Height="20" VerticalAlignment="Center">
                                    <Canvas Width="32" Height="28">
                                        <Rectangle Canvas.Left="2" Canvas.Top="6" Width="16" Height="16"
                                                   RadiusX="2" RadiusY="2"
                                                   Stroke="{DynamicResource WsTextPrimaryBrush}" StrokeThickness="1.6" Fill="Transparent"/>
                                        <Ellipse Canvas.Left="14" Canvas.Top="4" Width="16" Height="16"
                                                 Stroke="{DynamicResource WsTextPrimaryBrush}" StrokeThickness="1.6" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xE96E;" FontSize="10" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Popup x:Name="ShapesPalettePopup"
                               StaysOpen="False"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource WsSurfaceBrush}"
                                    BorderBrush="{DynamicResource WsBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,8"
                                    MaxWidth="300">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.35" Color="#000000"/>
                                </Border.Effect>
                                <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <Expander Header="Базовые"
                                                  IsExpanded="True"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                            <UniformGrid x:Name="ShapesPaletteBasicGrid"
                                                         Columns="4"
                                                         Margin="0,4,0,6"/>
                                        </Expander>
                                        <Expander Header="Блок-схема"
                                                  IsExpanded="True"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                            <UniformGrid x:Name="ShapesPaletteFlowGrid"
