                                <RotateTransform Angle="-45"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                    <Button x:Name="CommentButton" Style="{StaticResource ToolbarButtonStyle}" Click="Comment_Click"
                            ToolTip="Комментарий">
                        <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xE90A;"/>
                    </Button>

                    <Border Width="1" Height="28" Background="{DynamicResource WsBorderBrush}" Margin="6,0,10,0" VerticalAlignment="Center"/>

                    <StackPanel x:Name="ColorPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                        <Button Background="#111111" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#FF3B30" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#34C759" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#007AFF" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#FFD60A" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#FF2DDA" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#32D7FF" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#FF9500" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#AF52DE" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button Background="#30B0C7" Style="{StaticResource ColorButtonStyle}" Click="Color_Click"/>
                        <Button x:Name="MainToolbarColorPickerButton"
                                Style="{StaticResource ToolbarButtonStyle}"
                                ToolTip="Свой цвет"
                                Click="MainToolbarColorPicker_Click"
                                Margin="2,0,0,0">
                            <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xE790;"/>
                        </Button>
                    </StackPanel>

                    <Border Width="1" Height="28" Background="{DynamicResource WsBorderBrush}" Margin="6,0,8,0" VerticalAlignment="Center"/>

                    <StackPanel x:Name="ToolbarActionsPanel" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="UndoButton" Style="{StaticResource ToolbarButtonStyle}" Click="Undo_Click"
                                ToolTip="Отменить (Ctrl+Z)">
                            <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xE7A7;"/>
                        </Button>
                        <Button x:Name="RedoButton" Style="{StaticResource ToolbarButtonStyle}" Click="Redo_Click"
                                ToolTip="Повторить (Ctrl+Y)">
                            <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xE7A6;"/>
                        </Button>
                        <Button x:Name="ClearBoardButton" Style="{StaticResource ToolbarButtonStyle}" Click="ClearBoard_Click"
                                ToolTip="Очистить доску">
                            <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}" Text="&#xE74D;"/>
                        </Button>
                        <Button x:Name="AddImageButton" Style="{StaticResource ToolbarButtonStyle}" Click="AddImage_Click"
                                ToolTip="Добавить изображение">
                            <Grid Width="20" Height="20">
                                <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}"
                                           Text="&#xE8B9;"
                                           FontSize="16"/>
                                <Border Width="11" Height="11"
                                        CornerRadius="6"
                                        Background="{DynamicResource WsSurfaceBrush}"
                                        BorderBrush="{DynamicResource WsTextPrimaryBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,-2,-1">
                                    <TextBlock Style="{StaticResource ToolbarMdl2IconStyle}"
                                               Text="&#xE710;"
                                               FontSize="8"
                                               Margin="0,-1,0,0"/>
                                </Border>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Click="ExportPng_Click"
                                ToolTip="Экспорт PNG" Padding="8,8" MinWidth="44">
                            <TextBlock Style="{StaticResource ToolbarBadgeLabelStyle}" Text="PNG"/>
                        </Button>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Click="ExportPdf_Click"
                                ToolTip="Экспорт PDF" Padding="8,8" MinWidth="44">
                            <TextBlock Style="{StaticResource ToolbarBadgeLabelStyle}" Text="PDF"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource WsSurfaceBrush}"
                    ClipToBounds="True">
                <Grid>
                    <Grid x:Name="Viewport"
                          Focusable="True"
                          MouseDown="Viewport_MouseDown"
                          MouseMove="Viewport_MouseMove"
                          MouseUp="Viewport_MouseUp"
                          MouseWheel="Viewport_MouseWheel"
                          Background="Transparent">

                        <Canvas x:Name="BoardCanvas" Width="50000" Height="50000" Background="Transparent">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="BoardScale" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="BoardTranslate" X="0" Y="0"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                        </Canvas>
                        <Canvas x:Name="CursorCanvas"
                                Width="50000"
                                Height="50000"
                                IsHitTestVisible="False">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding ElementName=BoardScale, Path=ScaleX}"
                                                    ScaleY="{Binding ElementName=BoardScale, Path=ScaleY}"/>
                                    <TranslateTransform X="{Binding ElementName=BoardTranslate, Path=X}"
                                                        Y="{Binding ElementName=BoardTranslate, Path=Y}"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                        </Canvas>
                    </Grid>

                    <!-- Плавающая панель над выбранной фигурой (как в Figma) -->
                    <Border x:Name="SelectionToolbarPanel"
                            Visibility="Collapsed"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Margin="0"
                            Padding="10,8"
                            CornerRadius="12"
                            Background="#242428"
                            BorderBrush="#5B5B66"
                            BorderThickness="1"
                            Panel.ZIndex="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.35" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel x:Name="SelectionToolbarShapeHost"
                                        Orientation="Horizontal"
                                        Margin="0,0,10,0">
                                <Button x:Name="SelectionToolbarShapeButton"
                                        Height="30"
                                        Padding="6,2"
                                        Margin="0,0,0,0"
                                        Cursor="Hand"
                                        Background="#3A3A3C"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"
                                        ToolTip="Вид фигуры"
                                        Click="SelectionToolbarShapeButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="28" Height="18" VerticalAlignment="Center">
                                            <Canvas Width="36" Height="26">
                                                <Rectangle Canvas.Left="2" Canvas.Top="7" Width="16" Height="16"
                                                           RadiusX="2" RadiusY="2"
                                                           Stroke="#CCCCCC" StrokeThickness="1.6" Fill="Transparent"/>
                                                <Ellipse Canvas.Left="16" Canvas.Top="5" Width="16" Height="16"
                                                         Stroke="#CCCCCC" StrokeThickness="1.6" Fill="Transparent"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="▾" Margin="4,0,0,0" FontSize="10" Foreground="#CCCCCC"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Popup x:Name="SelectionToolbarShapePopup"
                                       StaysOpen="False"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Background="#1E1E20"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="8">
                                        <ScrollViewer MaxHeight="380" Width="252">
                                            <StackPanel>
                                                <Expander Header="Базовые" IsExpanded="True" Foreground="#CCCCCC"
                                                          Background="Transparent" BorderThickness="0">
                                                    <UniformGrid x:Name="SelectionToolbarShapeBasicGrid"
                                                                 Columns="4" Margin="0,4,0,6"/>
                                                </Expander>
                                                <Expander Header="Блок-схема" IsExpanded="True" Foreground="#CCCCCC"
                                                          Background="Transparent" BorderThickness="0">
                                                    <UniformGrid x:Name="SelectionToolbarShapeFlowGrid"
                                                                 Columns="4" Margin="0,4,0,0"/>
                                                </Expander>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <StackPanel x:Name="SelectionToolbarStyleHost"
                                        Orientation="Horizontal"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="SelectionToolbarFillButton"
                                            Style="{StaticResource SelectionToolbarColorChipStyle}"
                                            Width="36"
                                            Height="30"
                                            VerticalAlignment="Center"
                                            Click="SelectionToolbarFillButton_Click"
                                            ToolTip="Заливка">
                                        <Grid Width="22" Height="22">
                                            <Ellipse x:Name="SelectionToolbarFillSwatch"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center"
                                                     HorizontalAlignment="Center"
                                                     Fill="#111111"/>
                                            <TextBlock Text="▼"
                                                       FontSize="7"
                                                       Foreground="#666666"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </Button>
                                    <Button x:Name="SelectionToolbarStrokeButton"
                                            Style="{StaticResource SelectionToolbarColorChipStyle}"
                                            Width="36"
                                            Height="30"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            Click="SelectionToolbarStrokeButton_Click"
                                            ToolTip="Цвет обводки">
                                        <Grid Width="22" Height="22">
                                            <Ellipse x:Name="SelectionToolbarStrokeSwatch"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center"
                                                     HorizontalAlignment="Center"
                                                     Fill="#111111"/>
                                            <TextBlock Text="▼"
                                                       FontSize="7"
                                                       Foreground="#666666"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                                <Popup x:Name="SelectionToolbarFillPopup"
                                       StaysOpen="False"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Background="#000000"
                                            CornerRadius="12"
                                            Padding="12,10"
                                            BorderBrush="#404040"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.5" Color="#000000"/>
                                        </Border.Effect>
                                        <StackPanel MinWidth="300">
                                            <StackPanel x:Name="FillModeButtonRow"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,12">
                                                <Button x:Name="FillModeSolidBtn"
                                                        Tag="solid"
                                                        Margin="4,0"
                                                        Padding="14,8"
                                                        Cursor="Hand"
                                                        Click="FillModeButton_Click"
                                                        Content="Заливка"/>
                                                <Button x:Name="FillModeTintBtn"
                                                        Tag="tint"
                                                        Margin="4,0"
                                                        Padding="14,8"
                                                        Cursor="Hand"
                                                        Click="FillModeButton_Click"
                                                        Content="Прозрачная"/>
                                                <Button x:Name="FillModeStrokeBtn"
                                                        Tag="stroke"
                                                        Margin="4,0"
                                                        Padding="14,8"
                                                        Cursor="Hand"
                                                        Click="FillModeButton_Click"
                                                        Content="Без заливки"/>
                                            </StackPanel>
                                            <TextBlock Text="Цвет заливки"
                                                       Foreground="#CCCCCC"
                                                       Margin="0,0,0,6"
                                                       FontSize="12"/>
                                            <UniformGrid x:Name="FillPaletteGridFill" Rows="2" Columns="11"/>
                                            <Button x:Name="FillPaletteCustomColorBtn"
                                                    Margin="0,12,0,0"
                                                    Padding="10,8"
                                                    HorizontalAlignment="Stretch"
                                                    Cursor="Hand"
                                                    Click="FillPaletteCustomColorBtn_Click"
                                                    Content="Палитра…"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                                <Popup x:Name="SelectionToolbarStrokePopup"
                                       StaysOpen="False"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Background="#000000"
                                            CornerRadius="12"
                                            Padding="12,10"
                                            BorderBrush="#404040"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.5" Color="#000000"/>
                                        </Border.Effect>
                                        <StackPanel MinWidth="300">
                                            <TextBlock Text="Цвет контура"
                                                       Foreground="#CCCCCC"
                                                       Margin="0,0,0,6"
                                                       FontSize="12"/>
                                            <UniformGrid x:Name="FillPaletteGridStroke" Rows="2" Columns="11"/>
                                            <TextBlock Text="Стиль контура"
                                                       Foreground="#CCCCCC"
                                                       Margin="0,12,0,6"
                                                       FontSize="12"/>
                                            <StackPanel x:Name="StrokeStyleRow"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,2">
                                                <Button x:Name="StrokeStyleSolidBtn"
                                                        Tag="solid"
                                                        Margin="3,0"
                                                        Padding="10,6"
                                                        Cursor="Hand"
                                                        Click="StrokeStyleButton_Click"
                                                        Content="Сплошная"/>
                                                <Button x:Name="StrokeStyleDashBtn"
                                                        Tag="dash"
                                                        Margin="3,0"
                                                        Padding="10,6"
                                                        Cursor="Hand"
                                                        Click="StrokeStyleButton_Click"
                                                        Content="Штрих"/>
                                                <Button x:Name="StrokeStyleDotBtn"
                                                        Tag="dot"
                                                        Margin="3,0"
                                                        Padding="10,6"
                                                        Cursor="Hand"
                                                        Click="StrokeStyleButton_Click"
                                                        Content="Точки"/>
                                                <Button x:Name="StrokeStyleDashDotBtn"
                                                        Tag="dashdot"
                                                        Margin="3,0"
                                                        Padding="10,6"
                                                        Cursor="Hand"
                                                        Click="StrokeStyleButton_Click"
                                                        Content="Штрих-пунктир"/>
                                            </StackPanel>
                                            <StackPanel x:Name="ConnectorArrowSection"
                                                        Visibility="Collapsed"
                                                        Margin="0,12,0,0">
                                                <TextBlock Text="Наконечник (конец)"
                                                           Foreground="#CCCCCC"
                                                           Margin="0,0,0,6"
                                                           FontSize="12"/>
                                                <WrapPanel x:Name="ConnectorArrowEndRow"
                                                           HorizontalAlignment="Center">
                                                    <Button Tag="none" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowEnd_Click" Content="—"/>
                                                    <Button Tag="block" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowEnd_Click" Content="▶"/>
                                                    <Button Tag="open" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowEnd_Click" Content="›"/>
                                                    <Button Tag="diamond" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowEnd_Click" Content="◇"/>
                                                    <Button Tag="oval" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowEnd_Click" Content="○"/>
                                                </WrapPanel>
                                                <TextBlock Text="Наконечник (начало)"
                                                           Foreground="#CCCCCC"
                                                           Margin="0,10,0,6"
                                                           FontSize="12"/>
                                                <WrapPanel x:Name="ConnectorArrowStartRow"
                                                           HorizontalAlignment="Center">
                                                    <Button Tag="none" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowStart_Click" Content="—"/>
                                                    <Button Tag="block" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowStart_Click" Content="▶"/>
                                                    <Button Tag="open" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowStart_Click" Content="›"/>
                                                    <Button Tag="diamond" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowStart_Click" Content="◇"/>
                                                    <Button Tag="oval" Margin="3" Padding="8,5" Cursor="Hand"
                                                            Click="ConnectorArrowStart_Click" Content="○"/>
                                                </WrapPanel>
                                            </StackPanel>
                                            <Button x:Name="StrokePaletteCustomColorBtn"
                                                    Margin="0,12,0,0"
                                                    Padding="10,8"
                                                    HorizontalAlignment="Stretch"
                                                    Cursor="Hand"
                                                    Click="StrokePaletteCustomColorBtn_Click"
                                                    Content="Палитра…"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <StackPanel x:Name="SelectionToolbarTextHost"
                                        Orientation="Horizontal"
                                        Margin="0,0,10,0"
                                        Visibility="Collapsed"
                                        VerticalAlignment="Center">
                                <ComboBox x:Name="SelectionToolbarTextFontSizeCombo"
                                          Width="72"
                                          Height="34"
                                          Margin="0,0,6,0"
                                          FontWeight="SemiBold"
                                          VerticalContentAlignment="Center"
                                          ToolTip="Размер шрифта"
                                          SelectionChanged="SelectionToolbarTextFontSizeCombo_SelectionChanged"/>
                                <ToggleButton x:Name="SelectionToolbarTextBoldToggle"
                                              Width="34"
                                              Height="34"
                                              Margin="0,0,6,0"
                                              FontWeight="Bold"
                                              Content="B"
                                              ToolTip="Жирный"
                                              Click="SelectionToolbarTextBoldToggle_Click">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource WsPurpleBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource WsPurpleBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <Button x:Name="SelectionToolbarTextColorButton"
                                        Style="{StaticResource SelectionToolbarColorChipStyle}"
                                        Width="38"
                                        Height="34"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        ToolTip="Цвет текста"
                                        Click="SelectionToolbarTextColorButton_Click">
                                    <Grid Width="22" Height="22">
                                        <Ellipse x:Name="SelectionToolbarTextColorSwatch"
                                                 Width="18"
                                                 Height="18"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Fill="#111111"/>
                                        <TextBlock Text="▼"
                                                   FontSize="7"
                                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"/>
                                    </Grid>
                                </Button>
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="SelectionToolbarTextAlignLeftToggle"
                                                  Tag="left"
                                                  Width="34"
                                                  Height="34"
                                                  Margin="0,0,4,0"
                                                  Content="&#xE8E4;"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  ToolTip="По левому краю"
                                                  Click="SelectionToolbarTextAlign_Click">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource WsPurpleBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource WsPurpleBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <ToggleButton x:Name="SelectionToolbarTextAlignCenterToggle"
                                                  Tag="center"
                                                  Width="34"
                                                  Height="34"
                                                  Margin="0,0,4,0"
                                                  Content="&#xE8E3;"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  ToolTip="По центру"
                                                  Click="SelectionToolbarTextAlign_Click">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource WsPurpleBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource WsPurpleBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <ToggleButton x:Name="SelectionToolbarTextAlignRightToggle"
                                                  Tag="right"
                                                  Width="34"
                                                  Height="34"
                                                  Content="&#xE8E2;"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  ToolTip="По правому краю"
                                                  Click="SelectionToolbarTextAlign_Click">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource WsPurpleBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource WsPurpleBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                </StackPanel>
                            </StackPanel>
                            <Button x:Name="SelectionToolbarDeleteButton"
                                    Style="{StaticResource SelectionToolbarDeleteButtonStyle}"
                                    Width="36"
                                    Height="36"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    ToolTip="Удалить (Del)"
                                    Click="SelectionToolbarDelete_Click">
                                <Viewbox Width="18" Height="18">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE74D;"
                                               FontSize="16"
                                               Foreground="#FF6B6B"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsParticipantSidebarEdgeBrush}"
                    BorderThickness="1,0,0,0">
                <Grid Background="{DynamicResource WsSurfaceBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="18,16,18,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Участники"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                            <Border Width="32"
                                    Height="32"
                                    Background="{DynamicResource WsSurfaceMutedBrush}"
                                    CornerRadius="4"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                                <TextBlock x:Name="MembersCountText"
                                           Text="0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WsTextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource DarkActionButtonStyle}"
                                Padding="14,8"
                                Click="Invite_Click">
                            <TextBlock Text="Пригласить"/>
                        </Button>
                    </Grid>

                    <ListView x:Name="UsersListView"
                              Grid.Row="1"
                              Margin="10,0,10,12"
                              Style="{StaticResource BoardParticipantsListViewStyle}">
                        <ListView.Resources>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="ItemBd"
                                                    Background="Transparent"
                                                    CornerRadius="16"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBd" Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WsSurfaceMutedBrush}"
                                        BorderBrush="{DynamicResource WsBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="42" Height="42" VerticalAlignment="Top">
                                            <Border Background="{Binding AvatarFill}"
                                                    BorderBrush="{Binding AvatarStroke}"
                                                    BorderThickness="2"
                                                    CornerRadius="21"/>
                                            <TextBlock Text="{Binding Initials}"
                                                       Foreground="{Binding AvatarStroke}"
                                                       FontWeight="SemiBold"
                                                       FontSize="17"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Fill="{Binding PresenceDotFill}"
                                                     Stroke="{DynamicResource WsPresenceDotRingBrush}"
                                                     StrokeThickness="2"
                                                     HorizontalAlignment="Right"
                                                     VerticalAlignment="Bottom"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="16"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CurrentUserHint}"
                                                       Margin="0,2,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                       Visibility="{Binding CurrentUserHintVisibility}"/>
                                            <TextBlock Text="{Binding PresenceLabel}"
                                                       Margin="0,2,0,0"
                                                       FontSize="12"
                                                       Foreground="{Binding PresenceTextFill}"/>
                                            <Border Background="{Binding RoleBadgeBackground}"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="10"
                                                    Margin="0,6,0,0"
                                                    Padding="10,3">
                                                <TextBlock Text="{Binding RoleLabel}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding RoleBadgeForeground}"/>
                                            </Border>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Content="⋯"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                Width="34"
                                                Height="34"
                                                Padding="0"
                                                Margin="8,0,0,0"
                                                Click="ParticipantActionsButton_Click"
                                                Visibility="{Binding ActionVisibility}">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{Binding RoleActionLabel}"
                                                              Visibility="{Binding RoleActionVisibility}"
                                                              Click="ToggleParticipantRoleMenu_Click"/>
                                                    <MenuItem Header="Скопировать ID пользователя"
                                                              Click="CopyParticipantIdMenu_Click"/>
                                                    <Separator Visibility="{Binding RemoveActionVisibility}"/>
                                                    <MenuItem Header="Удалить с доски"
                                                              Foreground="#D92D20"
                                                              Visibility="{Binding RemoveActionVisibility}"
                                                              Click="RemoveParticipantMenu_Click"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.ColumnSpan="2">
                <Grid HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,18,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="ChatWidget"
                            Grid.Row="0"
                            Width="360"
                            MinHeight="320"
                            MaxHeight="520"
                            Background="{DynamicResource WsChatPanelBgBrush}"
                            BorderBrush="{DynamicResource WsChatPanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            ClipToBounds="True"
                            Visibility="Collapsed"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="180"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="16,14,16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Чат"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                                <Button Grid.Column="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource WsTextSecondaryBrush}"
                                        FontSize="18"
                                        Cursor="Hand"
                                        Click="CloseChat_Click"
                                        Content="×"/>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          x:Name="ChatMessagesScrollViewer"
                                          Margin="16,0,16,12"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="False">
                                <!-- Запас справа под вертикальный скроллбар, чтобы не наезжал на пузыри -->
                                <Border Padding="0,0,18,0">
                                    <ItemsControl x:Name="ChatMessagesItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding HeaderText}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                               HorizontalAlignment="{Binding HeaderAlignment}"/>
                                                    <Border HorizontalAlignment="{Binding BubbleAlignment}"
                                                            MaxWidth="280"
                                                            Margin="0,4,0,0"
                                                            CornerRadius="14"
                                                            Padding="12,8"
                                                            Background="{Binding BubbleBackground}"
                                                            ContextMenuOpening="ChatBubble_ContextMenuOpening">
                                                        <Border.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Редактировать"
                                                                          Click="ChatMessageEdit_Click"/>
                                                                <MenuItem Header="Удалить"
                                                                          Foreground="#DC2626"
                                                                          Click="ChatMessageDelete_Click"/>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <TextBlock Text="{Binding Text}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{Binding TextForeground}"/>
                                                    </Border>
                                                    <TextBlock Text="изменено"
                                                               FontSize="11"
                                                               FontStyle="Italic"
                                                               Foreground="{DynamicResource WsTextMutedBrush}"
                                                               Margin="0,3,0,0"
                                                               HorizontalAlignment="{Binding BubbleAlignment}"
                                                               Visibility="{Binding EditedBadgeVisibility}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </ScrollViewer>

                            <Grid Grid.Row="2" Margin="16,0,16,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="ChatInputBox"
                                         Height="42"
                                         VerticalContentAlignment="Center"
                                         Padding="14,0"
                                         Background="{DynamicResource WsChatInputBgBrush}"
                                         BorderBrush="{DynamicResource WsBorderBrush}"
                                         Foreground="{DynamicResource WsTextPrimaryBrush}"
                                         BorderThickness="1"
                                         Text=""
                                         KeyDown="ChatInputBox_KeyDown"/>

                                <Button Grid.Column="1"
                                        Width="42"
                                        Height="42"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource DarkActionButtonStyle}"
                                        Click="ChatSend_Click">
                                    <TextBlock Text="➜"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom">
                        <Button x:Name="ChatFabButton"
                                Style="{StaticResource ChatFabButtonStyle}"
                                Click="ToggleChat_Click">
                            <TextBlock Text="💬" FontSize="18"/>
                        </Button>
                        <Border x:Name="ChatUnreadBadge"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-2,-2,0"
                                MinWidth="20"
                                Height="20"
                                CornerRadius="10"
                                Padding="5,0"
                                Background="{DynamicResource WsPurpleBrush}"
                                BorderBrush="{DynamicResource WsSurfaceBrush}"
                                BorderThickness="2"
                                Visibility="Collapsed">
                            <TextBlock x:Name="ChatUnreadBadgeText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
