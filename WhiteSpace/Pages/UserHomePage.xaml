<Page x:Class="WhiteSpace.Pages.UserHomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная"
      Background="{DynamicResource WsPageBgBrush}"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#334155"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#00000000"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#0F172A"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#334155"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WsTopButtonPressBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsPressed" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                            </MultiTrigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryTopButtonStyle" TargetType="Button" BasedOn="{StaticResource TopButtonStyle}">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="BorderBrush" Value="#8B5CF6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#A78BFA"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#8B5CF6"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#6D28D9"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.97"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.97"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#A78BFA"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewModeButtonStyle" TargetType="Button" BasedOn="{StaticResource TopButtonStyle}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="BoardCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{DynamicResource WsSurfaceBrush}"
                                BorderBrush="{DynamicResource WsBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="TranslateTransform" Y="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#A5B4FC"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         To="-2"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#E2E8F0"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         To="0"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.985"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.99"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         To="1"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         To="-2"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootPageGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource WsSidebarBgBrush}"
                BorderBrush="{DynamicResource WsSidebarBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="16,18,16,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,26">
                        <Border Width="40"
                                Height="40"
                                Background="#8B5CF6"
                                CornerRadius="13">
                            <TextBlock Text="W"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="WhiteSpace"
                                   Margin="12,4,0,0"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="24"/>
                    </StackPanel>

                    <Button x:Name="MyBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="MyBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▦" FontSize="16"/>
                            <TextBlock Text="Мои доски" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SharedBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SharedBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◌" FontSize="16"/>
                            <TextBlock Text="Общие доски" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="RecentBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="RecentBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◔" FontSize="16"/>
                            <TextBlock Text="Недавние" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="FavoriteBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="FavoriteBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="★" FontSize="16"/>
                            <TextBlock Text="Избранные" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource WsSidebarBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="14,14,14,16">
                    <Grid>
                        <Button x:Name="ProfileButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch"
                                Click="ProfileButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="42"
                                        Height="42"
                                        CornerRadius="21"
                                        Background="#312E81"
                                        BorderBrush="#8B5CF6"
                                        BorderThickness="1.5">
                                    <TextBlock x:Name="UserInitialsTextBlock"
                                               Text="W"
                                               Foreground="#FFFFFF"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="SidebarUserNameTextBlock"
                                               Text="Пользователь"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="SidebarUserEmailTextBlock"
                                               Text="email@example.com"
                                               Foreground="{DynamicResource WsTextMutedBrush}"
                                               FontSize="11"
                                               Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{DynamicResource WsPageBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="GreetingTextBlock"
                                   Text="Здравствуйте!"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="HeaderEmailTextBlock"
                                   Text="email@example.com"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                   FontSize="15"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Margin="0,0,10,0" VerticalAlignment="Center">
                            <Button x:Name="NotificationCenterButton"
                                    Style="{StaticResource TopButtonStyle}"
                                    Padding="16,0"
                                    Click="NotificationCenter_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔔" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Уведомления" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Border x:Name="NotificationUnreadBadge"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-6,-4,0"
                                    MinWidth="20"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="#DC2626"
                                    Visibility="Collapsed"
                                    Padding="5,0">
                                <TextBlock x:Name="NotificationUnreadBadgeText"
                                           Text="0"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <Button Style="{StaticResource HelpRoundButtonStyle}"
                                Margin="0,0,10,0"
                                Click="Help_Click"/>
                        <Button Style="{StaticResource PrimaryTopButtonStyle}"
                                Click="CreateBoard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Создать доску"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource TopButtonStyle}"
                                Margin="8,0,0,0"
                                Click="JoinByCode_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⟷" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="По коду"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource TopButtonStyle}"
                                Margin="8,0,0,0"
                                Click="Logout_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⇥" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Выход"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Height="42">
                        <Border Background="{DynamicResource WsSurfaceMutedBrush}"
                                BorderBrush="{DynamicResource WsBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"/>
                        <Grid Margin="14,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⌕"
                                       Foreground="{DynamicResource WsTextSecondaryBrush}"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchTextBox"
                                     Grid.Column="1"
                                     Margin="10,0,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     Foreground="{DynamicResource WsTextPrimaryBrush}"
                                     TextChanged="SearchTextBox_TextChanged"/>
                        </Grid>
                    </Grid>

                    <ComboBox x:Name="SortComboBox"
                              Grid.Column="1"
                              Width="180"
                              Height="42"
                              Margin="14,0,10,0"
                              VerticalContentAlignment="Center"
                              SelectionChanged="SortComboBox_SelectionChanged">
                        <ComboBoxItem Content="Новые сначала" IsSelected="True"/>
                        <ComboBoxItem Content="Старые сначала"/>
                        <ComboBoxItem Content="Название А-Я"/>
                        <ComboBoxItem Content="Название Я-А"/>
                    </ComboBox>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="LargeViewButton"
                                Style="{StaticResource ViewModeButtonStyle}"
                                Click="LargeViewButton_Click"
                                ToolTip="Плитка">
                            <Grid Width="16" Height="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Margin="0,0,2,2" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="0" Grid.Column="1" Margin="2,0,0,2" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="1" Grid.Column="0" Margin="0,2,2,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="1" Grid.Column="1" Margin="2,2,0,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Grid>
                        </Button>
                        <Button x:Name="CompactViewButton"
                                Style="{StaticResource ViewModeButtonStyle}"
                                Margin="0"
                                Click="CompactViewButton_Click"
                                ToolTip="Список">
                            <StackPanel Width="16" Height="16" VerticalAlignment="Center">
                                <Border Height="2" Margin="0,1,0,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Height="2" Margin="0,4,0,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Height="2" Margin="0,4,0,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="24,20,24,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="SectionTitleTextBlock"
                               Text="Мои доски"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                    <TextBlock x:Name="SectionSubtitleTextBlock"
                               Text="0 досок"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource WsTextSecondaryBrush}"
                               FontSize="14"/>
                </StackPanel>
            </Grid>

            <!-- Уведомление: справа сверху, поверх контента -->
            <Border x:Name="HomeToastBorder"
                    Grid.RowSpan="4"
                    Panel.ZIndex="100"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,20,28,0"
                    MinWidth="280"
                    MaxWidth="420"
                    Padding="16,14"
                    CornerRadius="14"
                    Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsBorderBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="3"
                                      Opacity="0.22"
                                      Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Уведомление"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                        <TextBlock x:Name="HomeToastMessageText"
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="34"
                            Height="34"
                            Margin="14,0,0,0"
                            VerticalAlignment="Top"
                            Background="{DynamicResource WsSurfaceMutedBrush}"
                            BorderBrush="{DynamicResource WsBorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="Закрыть"
                            Click="HomeToastDismiss_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="✕"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"/>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="3"
                          Margin="24,0,24,24"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ItemsControl x:Name="BoardsItemsControl"
                                  ItemsSource="{Binding VisibleBoards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="CardHost"
                                      Width="{Binding DataContext.BoardCardWidth, RelativeSource={RelativeSource AncestorType=Page}}"
                                      Height="{Binding DataContext.BoardCardHeight, RelativeSource={RelativeSource AncestorType=Page}}"
                                      Margin="0,0,18,18">
                                    <Border Background="{DynamicResource WsSurfaceBrush}"
                                            BorderBrush="{DynamicResource WsBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="24"
                                            ClipToBounds="True"
                                            Tag="{Binding Id}"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="OpenBoardCard_Click"
                                            Opacity="0"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Открыть"
                                                          Click="OpenBoardFromContextMenu_Click"/>
                                                <MenuItem Visibility="{Binding DeleteVisibility}"
                                                          Click="DeleteBoardFromContextMenu_Click">
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="✕"
                                                                       Foreground="{DynamicResource WsDangerForegroundBrush}"
                                                                       FontWeight="Bold"
                                                                       FontSize="13"
                                                                       Margin="0,0,8,0"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="Удалить доску"
                                                                       Foreground="{DynamicResource WsDangerForegroundBrush}"
                                                                       FontSize="13"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="CardTranslateTransform" Y="12"/>
                                        </Border.RenderTransform>
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1"
                                                                         Duration="0:0:0.28"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         To="0"
                                                                         Duration="0:0:0.28">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0.96"
                                                                         Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1"
                                                                         Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0.9"
                                                                         Duration="0:0:0.08"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0.96"
                                                                         Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                                    Margin="12,12,12,0"
                                                    Height="104"
                                                    CornerRadius="16"
                                                    ClipToBounds="True"
                                                    BorderBrush="{DynamicResource WsBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="#FFF8FAFC">
                                                <Grid>
                                                    <Border>
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="{Binding AccentStart}" Offset="0"/>
                                                                <GradientStop Color="{Binding AccentEnd}" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <Grid Margin="10,10,10,0">
                                                        <Button Width="32"
                                                                Height="32"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,0,0,0"
                                                                Padding="0"
                                                                Background="{DynamicResource WsSurfaceBrush}"
                                                                BorderBrush="{DynamicResource WsBorderBrush}"
                                                                BorderThickness="1"
                                                                Cursor="Hand"
                                                                ToolTip="В избранное"
                                                                Click="ToggleFavorite_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Opacity" Value="0"/>
                                                                    <Setter Property="Panel.ZIndex" Value="2"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                            <Setter Property="Opacity" Value="1"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=CardHost}" Value="True">
                                                                            <Setter Property="Opacity" Value="1"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="8">
                                                                        <TextBlock x:Name="StarGlyph"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   FontSize="16"
                                                                                   FontWeight="Bold"
                                                                                   Text="☆"
                                                                                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                            <Setter TargetName="StarGlyph" Property="Text" Value="★"/>
                                                                            <Setter TargetName="StarGlyph" Property="Foreground" Value="#FACC15"/>
                                                                        </DataTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <Border HorizontalAlignment="Right"
                                                                Height="24"
                                                                Margin="0,4,40,0"
                                                                Padding="10,0"
                                                                Background="{Binding RoleBadgeBackground}"
                                                                CornerRadius="12">
                                                            <TextBlock Text="{Binding RoleLabel}"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{Binding RoleBadgeForeground}"
                                                                       FontSize="11"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="1" Margin="18,14,18,16">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{DynamicResource WsTextPrimaryBrush}"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="1"
                                                           Margin="0,8,0,0"
                                                           Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Subtitle}"/>

                                                <StackPanel Grid.Row="2"
                                                            Margin="0,12,0,0"
                                                            Orientation="Horizontal">
                                                    <TextBlock Text="○"
                                                               Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{Binding CreatedText}"
                                                               Margin="6,0,0,0"
                                                               Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                               FontSize="12"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border x:Name="NoBoardsState"
                            Background="{DynamicResource WsSurfaceBrush}"
                            BorderBrush="{DynamicResource WsBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="32"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="68"
                                    Height="68"
                                    Background="{DynamicResource WsSurfaceMutedBrush}"
                                    CornerRadius="34">
                                <TextBlock Text="+"
                                           Foreground="{DynamicResource WsPurpleBrush}"
                                           FontSize="34"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="EmptyStateTitleTextBlock"
                                       Text="Здесь пока пусто"
                                       Margin="0,18,0,0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource WsTextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyStateSubtitleTextBlock"
                                       Text="Создайте первую доску или подключитесь по коду."
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource WsTextSecondaryBrush}"
                                       TextAlignment="Center"/>
                            <Button x:Name="EmptyStateActionButton"
                                    Margin="0,22,0,0"
                                    Style="{StaticResource PrimaryTopButtonStyle}"
                                    Click="CreateBoard_Click">
                                <TextBlock Text="Создать доску"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Popup x:Name="NotificationCenterPopup"
               PlacementTarget="{Binding ElementName=NotificationCenterButton}"
               Placement="Bottom"
               HorizontalOffset="-200"
               VerticalOffset="4"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Width="380"
                    MaxHeight="440"
                    CornerRadius="14"
                    Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsBorderBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Центр уведомлений"
                               Margin="16,14,16,8"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                    <ListBox x:Name="NotificationListBox"
                             Grid.Row="1"
                             Margin="8,0,8,0"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="NotificationListBox_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource WsBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding BoardTitle}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding ReceivedLocal}"
                                                       HorizontalAlignment="Right"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding SenderName}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource WsTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding MessagePreview}"
                                                   Margin="0,6,0,0"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource WsTextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="NotificationEmptyHint"
                               Grid.Row="1"
                               Margin="24"
                               Text="Нет уведомлений о сообщениях в чатах досок."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource WsTextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource WsBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="12,10">
                        <Button HorizontalAlignment="Stretch"
                                Style="{StaticResource TopButtonStyle}"
                                Margin="0"
                                Click="NotificationClearAll_Click">
                            <TextBlock Text="Очистить список"/>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Page>
