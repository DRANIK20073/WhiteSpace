<Page x:Class="WhiteSpace.Pages.UserHomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная"
      Background="{DynamicResource WsPageBgBrush}"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#334155"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#00000000"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#0F172A"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#334155"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource WsTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource WsSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WsBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WsTopButtonPressBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsPressed" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WsSurfaceMutedBrush}"/>
                            </MultiTrigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryTopButtonStyle" TargetType="Button" BasedOn="{StaticResource TopButtonStyle}">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="BorderBrush" Value="#8B5CF6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#A78BFA"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#8B5CF6"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#6D28D9"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.97"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.97"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#A78BFA"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewModeButtonStyle" TargetType="Button" BasedOn="{StaticResource TopButtonStyle}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="BoardCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{DynamicResource WsSurfaceBrush}"
                                BorderBrush="{DynamicResource WsBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="TranslateTransform" Y="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#A5B4FC"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         To="-2"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#E2E8F0"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         To="0"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.985"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.99"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         To="1"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="TranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         To="-2"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootPageGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource WsSidebarBgBrush}"
                BorderBrush="{DynamicResource WsSidebarBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="16,18,16,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,26">
                        <Border Width="40"
                                Height="40"
                                Background="#8B5CF6"
                                CornerRadius="13">
                            <TextBlock Text="W"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="WhiteSpace"
                                   Margin="12,4,0,0"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="24"/>
                    </StackPanel>

                    <Button x:Name="MyBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="MyBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▦" FontSize="16"/>
                            <TextBlock Text="Мои доски" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SharedBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SharedBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◌" FontSize="16"/>
                            <TextBlock Text="Общие доски" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="RecentBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="RecentBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◔" FontSize="16"/>
                            <TextBlock Text="Недавние" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource WsSidebarBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="14,14,14,16">
                    <Grid>
                        <Button x:Name="ProfileButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch"
                                Click="ProfileButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="42"
                                        Height="42"
                                        CornerRadius="21"
                                        Background="#312E81"
                                        BorderBrush="#8B5CF6"
                                        BorderThickness="1.5">
                                    <TextBlock x:Name="UserInitialsTextBlock"
                                               Text="W"
                                               Foreground="#FFFFFF"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="SidebarUserNameTextBlock"
                                               Text="Пользователь"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="SidebarUserEmailTextBlock"
                                               Text="email@example.com"
                                               Foreground="{DynamicResource WsTextMutedBrush}"
                                               FontSize="11"
                                               Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{DynamicResource WsPageBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="GreetingTextBlock"
                                   Text="Здравствуйте!"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="HeaderEmailTextBlock"
                                   Text="email@example.com"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                   FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource HelpRoundButtonStyle}"
                                Margin="0,0,10,0"
                                Click="Help_Click"/>
                        <Button Style="{StaticResource PrimaryTopButtonStyle}"
                                Click="CreateBoard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Создать доску"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource TopButtonStyle}"
                                Margin="8,0,0,0"
                                Click="JoinByCode_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⟷" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="По коду"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource TopButtonStyle}"
                                Margin="8,0,0,0"
                                Click="JoinByLink_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔗" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="По ссылке"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource TopButtonStyle}"
                                Margin="8,0,0,0"
                                Click="Logout_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⇥" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Выход"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Height="42">
                        <Border Background="{DynamicResource WsSurfaceMutedBrush}"
                                BorderBrush="{DynamicResource WsBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"/>
                        <Grid Margin="14,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⌕"
                                       Foreground="{DynamicResource WsTextSecondaryBrush}"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchTextBox"
                                     Grid.Column="1"
                                     Margin="10,0,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     Foreground="{DynamicResource WsTextPrimaryBrush}"
                                     TextChanged="SearchTextBox_TextChanged"/>
                        </Grid>
                    </Grid>

                    <ComboBox x:Name="SortComboBox"
                              Grid.Column="1"
                              Width="180"
                              Height="42"
                              Margin="14,0,10,0"
                              VerticalContentAlignment="Center"
                              SelectionChanged="SortComboBox_SelectionChanged">
                        <ComboBoxItem Content="Новые сначала" IsSelected="True"/>
                        <ComboBoxItem Content="Старые сначала"/>
                        <ComboBoxItem Content="Название А-Я"/>
                        <ComboBoxItem Content="Название Я-А"/>
                    </ComboBox>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="LargeViewButton"
                                Style="{StaticResource ViewModeButtonStyle}"
                                Click="LargeViewButton_Click"
                                ToolTip="Плитка">
                            <Grid Width="16" Height="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Margin="0,0,2,2" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="0" Grid.Column="1" Margin="2,0,0,2" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="1" Grid.Column="0" Margin="0,2,2,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Grid.Row="1" Grid.Column="1" Margin="2,2,0,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Grid>
                        </Button>
                        <Button x:Name="CompactViewButton"
                                Style="{StaticResource ViewModeButtonStyle}"
                                Margin="0"
                                Click="CompactViewButton_Click"
                                ToolTip="Список">
                            <StackPanel Width="16" Height="16" VerticalAlignment="Center">
                                <Border Height="2" Margin="0,1,0,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Height="2" Margin="0,4,0,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Border Height="2" Margin="0,4,0,0" CornerRadius="1"
                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="24,20,24,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="SectionTitleTextBlock"
                               Text="Мои доски"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WsTextPrimaryBrush}"/>
                    <TextBlock x:Name="SectionSubtitleTextBlock"
                               Text="0 досок"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource WsTextSecondaryBrush}"
                               FontSize="14"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="3"
                          Margin="24,0,24,24"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ItemsControl x:Name="BoardsItemsControl"
                                  ItemsSource="{Binding VisibleBoards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding DataContext.BoardCardWidth, RelativeSource={RelativeSource AncestorType=Page}}"
                                      Height="{Binding DataContext.BoardCardHeight, RelativeSource={RelativeSource AncestorType=Page}}"
                                      Margin="0,0,18,18">
                                    <Border Background="{DynamicResource WsSurfaceBrush}"
                                            BorderBrush="{DynamicResource WsBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Tag="{Binding Id}"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="OpenBoardCard_Click"
                                            Opacity="0"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="CardTranslateTransform" Y="12"/>
                                        </Border.RenderTransform>
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1"
                                                                         Duration="0:0:0.28"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         To="0"
                                                                         Duration="0:0:0.28">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0.96"
                                                                         Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1"
                                                                         Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0.9"
                                                                         Duration="0:0:0.08"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0.96"
                                                                         Duration="0:0:0.1"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="96"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" CornerRadius="18,18,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{Binding AccentStart}" Offset="0"/>
                                                        <GradientStop Color="{Binding AccentEnd}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid Margin="14,14,14,0">
                                                    <Border HorizontalAlignment="Right"
                                                            Height="24"
                                                            Padding="10,0"
                                                            Background="{Binding RoleBadgeBackground}"
                                                            CornerRadius="12">
                                                        <TextBlock Text="{Binding RoleLabel}"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding RoleBadgeForeground}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="1" Margin="18,16,18,16">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{DynamicResource WsTextPrimaryBrush}"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="1"
                                                           Margin="0,8,0,0"
                                                           Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Subtitle}"/>

                                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="○"
                                                                    Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                                   FontSize="12"/>
                                                        <TextBlock Text="{Binding CreatedText}"
                                                                   Margin="6,0,0,0"
                                                                    Foreground="{DynamicResource WsTextSecondaryBrush}"
                                                                   FontSize="12"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="1"
                                                            Width="34"
                                                            Height="34"
                                                            Background="{DynamicResource WsSurfaceMutedBrush}"
                                                            BorderBrush="{DynamicResource WsBorderBrush}"
                                                            BorderThickness="1"
                                                            Cursor="Hand"
                                                            Visibility="{Binding DeleteVisibility}"
                                                            CommandParameter="{Binding Id}"
                                                            Click="DeleteBoard_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="10">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <TextBlock Text="✕"
                                                                   Foreground="#D92D20"
                                                                   FontWeight="Bold"/>
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border x:Name="NoBoardsState"
                            Background="{DynamicResource WsSurfaceBrush}"
                            BorderBrush="{DynamicResource WsBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="32"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="68"
                                    Height="68"
                                    Background="{DynamicResource WsSurfaceMutedBrush}"
                                    CornerRadius="34">
                                <TextBlock Text="+"
                                           Foreground="{DynamicResource WsPurpleBrush}"
                                           FontSize="34"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="EmptyStateTitleTextBlock"
                                       Text="Здесь пока пусто"
                                       Margin="0,18,0,0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource WsTextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyStateSubtitleTextBlock"
                                       Text="Создайте первую доску или подключитесь по коду."
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource WsTextSecondaryBrush}"
                                       TextAlignment="Center"/>
                            <Button x:Name="EmptyStateActionButton"
                                    Margin="0,22,0,0"
                                    Style="{StaticResource PrimaryTopButtonStyle}"
                                    Click="CreateBoard_Click">
                                <TextBlock Text="Создать доску"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
