<Page x:Class="WhiteSpace.Pages.UserHomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная"
      Background="#F6F7FB"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#D8E0F0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#222D48"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#00000000"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#151D33"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#222D48"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E4E9F3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#F4F6FB"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#FFFFFF"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#ECEFF6"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.98"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#F4F6FB"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryTopButtonStyle" TargetType="Button" BasedOn="{StaticResource TopButtonStyle}">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#666666"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#333333"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#000000"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.97"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.97"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#666666"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewModeButtonStyle" TargetType="Button" BasedOn="{StaticResource TopButtonStyle}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="BoardCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="#FFFFFF"
                                BorderBrush="#E6EBF5"
                                BorderThickness="1"
                                CornerRadius="18"
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#C9D3E5"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Root"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#E6EBF5"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.985"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.985"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.02"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#10172A"
                BorderBrush="#1A2238"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="16,18,16,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,26">
                        <Border Width="40"
                                Height="40"
                                Background="#6C63FF"
                                CornerRadius="13">
                            <TextBlock Text="W"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="WhiteSpace"
                                   Margin="12,4,0,0"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="24"/>
                    </StackPanel>

                    <Button x:Name="MyBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="MyBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▦" FontSize="16"/>
                            <TextBlock Text="Мои доски" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SharedBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SharedBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◌" FontSize="16"/>
                            <TextBlock Text="Общие доски" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="RecentBoardsButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="RecentBoardsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◔" FontSize="16"/>
                            <TextBlock Text="Недавние" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="2"
                        BorderBrush="#25304A"
                        BorderThickness="0,1,0,0"
                        Padding="14,14,14,16">
                    <Grid>
                        <Button x:Name="ProfileButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Stretch"
                                Click="ProfileButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="42"
                                        Height="42"
                                        CornerRadius="21"
                                        Background="#17223B"
                                        BorderBrush="#4D67A6"
                                        BorderThickness="1.5">
                                    <TextBlock x:Name="UserInitialsTextBlock"
                                               Text="W"
                                               Foreground="#8AA5FF"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="SidebarUserNameTextBlock"
                                               Text="Пользователь"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="SidebarUserEmailTextBlock"
                                               Text="email@example.com"
                                               Foreground="#91A0C0"
                                               FontSize="11"
                                               Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Popup x:Name="ProfilePopup"
                               Placement="Top"
                               PlacementTarget="{Binding ElementName=ProfileButton}"
                               StaysOpen="False"
                               Closed="ProfilePopup_Closed">
                            <Border Width="260"
                                    Margin="0,0,0,10"
                                    Padding="16"
                                    Background="#FFFFFF"
                                    BorderBrush="#E7EBF4"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <StackPanel>
                                    <TextBlock Text="Настройки пользователя"
                                               FontWeight="Bold"
                                               FontSize="17"
                                               Foreground="#121A2F"/>
                                    <TextBlock x:Name="PopupUserNameTextBlock"
                                               Text="Пользователь"
                                               Margin="0,14,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#121A2F"/>
                                    <TextBlock x:Name="PopupUserEmailTextBlock"
                                               Text="email@example.com"
                                               Margin="0,4,0,0"
                                               Foreground="#6B7488"/>

                                    <Button Margin="0,16,0,8"
                                            Style="{StaticResource TopButtonStyle}"
                                            Click="ProfileSettings_Click">
                                        <TextBlock Text="Показать профиль"/>
                                    </Button>

                                    <Button Margin="0,0,0,8"
                                            Style="{StaticResource TopButtonStyle}"
                                            Click="RefreshDashboard_Click">
                                        <TextBlock Text="Обновить доски"/>
                                    </Button>

                                    <Button Style="{StaticResource PrimaryTopButtonStyle}"
                                            Click="Logout_Click">
                                        <TextBlock Text="Выйти"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#F6F7FB">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FFFFFF"
                    BorderBrush="#E7EBF4"
                    BorderThickness="0,0,0,1"
                    Padding="24,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="GreetingTextBlock"
                                   Text="Здравствуйте!"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="HeaderEmailTextBlock"
                                   Text="email@example.com"
                                   Margin="0,6,0,0"
                                   Foreground="#667085"
                                   FontSize="15"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource PrimaryTopButtonStyle}"
                                Click="CreateBoard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Создать доску"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource TopButtonStyle}"
                                Click="JoinByCode_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⟷" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Подключиться по коду"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource TopButtonStyle}"
                                Margin="0"
                                Click="Logout_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⇥" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Выход"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#E7EBF4"
                    BorderThickness="0,0,0,1"
                    Padding="24,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Height="42">
                        <Border Background="#F5F7FB"
                                BorderBrush="#E5EAF4"
                                BorderThickness="1"
                                CornerRadius="12"/>
                        <Grid Margin="14,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⌕"
                                       Foreground="#97A1B5"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchTextBox"
                                     Grid.Column="1"
                                     Margin="10,0,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     Foreground="#111827"
                                     TextChanged="SearchTextBox_TextChanged"/>
                        </Grid>
                    </Grid>

                    <ComboBox x:Name="SortComboBox"
                              Grid.Column="1"
                              Width="180"
                              Height="42"
                              Margin="14,0,10,0"
                              VerticalContentAlignment="Center"
                              SelectionChanged="SortComboBox_SelectionChanged">
                        <ComboBoxItem Content="Новые сначала" IsSelected="True"/>
                        <ComboBoxItem Content="Старые сначала"/>
                        <ComboBoxItem Content="Название А-Я"/>
                        <ComboBoxItem Content="Название Я-А"/>
                    </ComboBox>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="LargeViewButton"
                                Style="{StaticResource ViewModeButtonStyle}"
                                Click="LargeViewButton_Click"
                                Content="▥"/>
                        <Button x:Name="CompactViewButton"
                                Style="{StaticResource ViewModeButtonStyle}"
                                Margin="0"
                                Click="CompactViewButton_Click"
                                Content="☷"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="24,20,24,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="SectionTitleTextBlock"
                               Text="Мои доски"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock x:Name="SectionSubtitleTextBlock"
                               Text="0 досок"
                               Margin="0,4,0,0"
                               Foreground="#667085"
                               FontSize="14"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="3"
                          Margin="24,0,24,24"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ItemsControl x:Name="BoardsItemsControl"
                                  ItemsSource="{Binding VisibleBoards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding DataContext.BoardCardWidth, RelativeSource={RelativeSource AncestorType=Page}}"
                                      Height="{Binding DataContext.BoardCardHeight, RelativeSource={RelativeSource AncestorType=Page}}"
                                      Margin="0,0,18,18">
                                    <Border Background="#FFFFFF"
                                            BorderBrush="#E6EBF5"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Tag="{Binding Id}"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="OpenBoardCard_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="96"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" CornerRadius="18,18,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{Binding AccentStart}" Offset="0"/>
                                                        <GradientStop Color="{Binding AccentEnd}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Grid Margin="14,14,14,0">
                                                    <Border HorizontalAlignment="Right"
                                                            Height="24"
                                                            Padding="10,0"
                                                            Background="{Binding RoleBadgeBackground}"
                                                            CornerRadius="12">
                                                        <TextBlock Text="{Binding RoleLabel}"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding RoleBadgeForeground}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="1" Margin="18,16,18,16">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#111827"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="1"
                                                           Margin="0,8,0,0"
                                                           Foreground="#667085"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Subtitle}"/>

                                                <Grid Grid.Row="2" Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="○"
                                                                   Foreground="#7B8599"
                                                                   FontSize="12"/>
                                                        <TextBlock Text="{Binding CreatedText}"
                                                                   Margin="6,0,0,0"
                                                                   Foreground="#7B8599"
                                                                   FontSize="12"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="1"
                                                            Width="34"
                                                            Height="34"
                                                            Background="#F5F7FB"
                                                            BorderBrush="#E5EAF4"
                                                            BorderThickness="1"
                                                            Cursor="Hand"
                                                            Visibility="{Binding DeleteVisibility}"
                                                            CommandParameter="{Binding Id}"
                                                            Click="DeleteBoard_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="10">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <TextBlock Text="✕"
                                                                   Foreground="#D92D20"
                                                                   FontWeight="Bold"/>
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border x:Name="NoBoardsState"
                            Background="#FFFFFF"
                            BorderBrush="#E7EBF4"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="32"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="68"
                                    Height="68"
                                    Background="#EEF2FF"
                                    CornerRadius="34">
                                <TextBlock Text="+"
                                           Foreground="#6C63FF"
                                           FontSize="34"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="EmptyStateTitleTextBlock"
                                       Text="Здесь пока пусто"
                                       Margin="0,18,0,0"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#111827"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyStateSubtitleTextBlock"
                                       Text="Создайте первую доску или подключитесь по коду."
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="#667085"
                                       TextAlignment="Center"/>
                            <Button Margin="0,22,0,0"
                                    Style="{StaticResource PrimaryTopButtonStyle}"
                                    Click="CreateBoard_Click">
                                <TextBlock Text="Создать доску"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
