<Page x:Class="WhiteSpace.Pages.ForgotPasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Восстановление пароля"
      Background="{DynamicResource WsLoginPageBgBrush}"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="AnimatedPrimaryButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="10"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scaleTransform" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#A78BFA"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#8B5CF6"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#6D28D9"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.97"
                                                         Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.97"
                                                         Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="#A78BFA"
                                                        Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.03"
                                                         Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.03"
                                                         Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <PowerEase Power="2" EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Viewbox Stretch="Uniform" MaxWidth="800" MaxHeight="700">
        <Grid x:Name="AuthRootGrid" Width="700" Height="600">
            <Border Background="{DynamicResource WsSurfaceBrush}"
                    BorderBrush="{DynamicResource WsBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Width="450"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      Opacity="0.1"
                                      ShadowDepth="4"
                                      Color="#000000"/>
                </Border.Effect>

                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,30,0,30">
                        <TextBlock Text="WHITESPACE"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WsTextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Восстановите доступ к аккаунту"
                                   FontSize="16"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="60,0,60,40">
                        <TextBlock Text="Введите email, и мы отправим ссылку для смены пароля."
                                   TextWrapping="Wrap"
                                   FontSize="15"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}"
                                   Margin="0,0,0,20"/>

                        <ui:TextBox x:Name="EmailBox"
                                    PlaceholderText="Email"
                                    Icon="Mail20"
                                    FontSize="16"
                                    Margin="0,0,0,24"
                                    Background="{DynamicResource WsSurfaceBrush}"
                                    BorderBrush="{DynamicResource WsBorderBrush}"
                                    Foreground="{DynamicResource WsTextPrimaryBrush}"
                                    ClearButtonEnabled="True"
                                    KeyDown="EmailBox_KeyDown"/>

                        <Button Content="Отправить ссылку"
                                Style="{StaticResource AnimatedPrimaryButton}"
                                Height="45"
                                FontSize="18"
                                Background="#8B5CF6"
                                Foreground="#FFFFFF"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,0,24"
                                Click="SendResetLink_Click"/>

                        <TextBlock HorizontalAlignment="Center"
                                   Foreground="{DynamicResource WsTextSecondaryBrush}">
                            <Run Text="Вспомнили пароль? "/>
                            <Hyperlink Click="BackToLogin_Click"
                                       Foreground="{DynamicResource WsPurpleBrush}">
                                <Run Text="Вернуться ко входу"
                                     FontWeight="SemiBold"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</Page>
