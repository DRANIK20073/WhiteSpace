<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Светлая тема (макет: фон страницы Gray 50, карточки белые, текст Gray 900) -->
    <Color x:Key="WsPageBgColor">#FFF9FAFB</Color>
    <Color x:Key="WsSurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="WsSurfaceMutedColor">#FFF1F5F9</Color>
    <Color x:Key="WsTextPrimaryColor">#FF111827</Color>
    <Color x:Key="WsTextSecondaryColor">#FF64748B</Color>
    <Color x:Key="WsTextMutedColor">#FF94A3B8</Color>
    <Color x:Key="WsBorderColor">#FFE5E7EB</Color>

    <SolidColorBrush x:Key="WsPageBgBrush" Color="{StaticResource WsPageBgColor}"/>
    <SolidColorBrush x:Key="WsSurfaceBrush" Color="{StaticResource WsSurfaceColor}"/>
    <SolidColorBrush x:Key="WsSurfaceMutedBrush" Color="{StaticResource WsSurfaceMutedColor}"/>
    <SolidColorBrush x:Key="WsTextPrimaryBrush" Color="{StaticResource WsTextPrimaryColor}"/>
    <SolidColorBrush x:Key="WsTextSecondaryBrush" Color="{StaticResource WsTextSecondaryColor}"/>
    <SolidColorBrush x:Key="WsTextMutedBrush" Color="{StaticResource WsTextMutedColor}"/>
    <SolidColorBrush x:Key="WsBorderBrush" Color="{StaticResource WsBorderColor}"/>

    <SolidColorBrush x:Key="WsParticipantSidebarEdgeBrush" Color="{StaticResource WsBorderColor}"/>
    <SolidColorBrush x:Key="WsChatPanelBorderBrush" Color="{StaticResource WsBorderColor}"/>
    <SolidColorBrush x:Key="WsPresenceDotRingBrush" Color="#FFFFFFFF"/>

    <!-- Боковая панель главной (контраст к светлому контенту) -->
    <SolidColorBrush x:Key="WsSidebarBgBrush" Color="#FF1E293B"/>
    <SolidColorBrush x:Key="WsSidebarBorderBrush" Color="#FF334155"/>

    <!-- Чат на доске -->
    <SolidColorBrush x:Key="WsChatPanelBgBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="WsChatPeerBubbleBrush" Color="#FFF1F5F9"/>
    <SolidColorBrush x:Key="WsChatMineBubbleBrush" Color="#FF8B5CF6"/>
    <SolidColorBrush x:Key="WsChatPeerTextBrush" Color="#FF1E293B"/>
    <SolidColorBrush x:Key="WsChatInputBgBrush" Color="#FFF8FAFC"/>

    <!-- Легаси‑ключи -->
    <Color x:Key="WsPurpleColor">#FF8B5CF6</Color>
    <Color x:Key="WsBlueColor">#FF3B82F6</Color>
    <Color x:Key="WsDarkSlateColor">#FF1E293B</Color>
    <Color x:Key="WsNeutralGrayColor">#FF64748B</Color>
    <SolidColorBrush x:Key="WsPurpleBrush" Color="{StaticResource WsPurpleColor}"/>
    <SolidColorBrush x:Key="WsBlueBrush" Color="{StaticResource WsBlueColor}"/>
    <SolidColorBrush x:Key="WsDarkSlateBrush" Color="{StaticResource WsDarkSlateColor}"/>
    <SolidColorBrush x:Key="WsNeutralGrayBrush" Color="{StaticResource WsNeutralGrayColor}"/>

    <LinearGradientBrush x:Key="WsPurpleBlueGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#8B5CF6" Offset="0"/>
        <GradientStop Color="#3B82F6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WsLoginPageBgBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F9FAFB" Offset="0"/>
        <GradientStop Color="#EDE9FE" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WsViewportGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F5F3FF" Offset="1"/>
    </LinearGradientBrush>

    <Duration x:Key="WsUiFadeDuration">0:0:0.28</Duration>
    <QuadraticEase x:Key="WsEaseOut" EasingMode="EaseOut"/>

    <!-- Подсветка «призрачных» кнопок (тулбар, превью наведения на обычные кнопки) -->
    <SolidColorBrush x:Key="WsTopButtonPressBrush" Color="#FFEDE9FE"/>

    <!-- Ключи WPF UI (Fluent ComboBox) → палитра: сохраняется ControlTemplate, меняются только кисти -->
    <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource WsSurfaceColor}"/>
    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource WsSurfaceMutedColor}"/>
    <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="{StaticResource WsSurfaceColor}"/>
    <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="{StaticResource WsPageBgColor}"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled" Color="{StaticResource WsBorderColor}"/>
    <SolidColorBrush x:Key="ComboBoxForeground" Color="{StaticResource WsTextPrimaryColor}"/>
    <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource WsSurfaceColor}"/>
    <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="{StaticResource WsBorderColor}"/>
    <SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground" Color="{StaticResource WsTextSecondaryColor}"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="{StaticResource WsPurpleColor}"/>
    <SolidColorBrush x:Key="ComboBoxItemPillFillBrush" Color="{StaticResource WsPurpleColor}"/>
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{StaticResource WsSurfaceMutedColor}"/>
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="{StaticResource WsTextPrimaryColor}"/>
    <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="{StaticResource WsTextMutedColor}"/>
</ResourceDictionary>
